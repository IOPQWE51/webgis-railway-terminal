# ======== 前端公开可用 (本地调试用) ========
# OpenWeatherMap API Key - 气象雷达
VITE_OWM_KEY=your_openweathermap_api_key_here

# WeatherAPI Key - 环境数据采集
VITE_WEATHER_API_KEY=your_weatherapi_key_here

# Google Maps API Key - 地理编码（需要启用 Geocoding API）
# 获取方式：https://developers.google.com/maps/documentation/geocoding/get-api-key
# 建议设置：HTTP referrer 限制 + 日用量限额
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox Access Token - 交通流量、地形数据
# 获取方式：https://account.mapbox.com/
# 免费额度：100,000次/月
# 建议创建两个 token：一个开发用，一个生产用
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# ======== 绝对机密！仅限云端后端读取 (不要带 VITE_ 前缀) ========
# WeatherAPI Key (后端用)
WEATHER_API_KEY=your_weatherapi_key_here

# Astro App ID & Secret
ASTRO_APP_ID=your_astro_app_id_here
ASTRO_APP_SECRET=your_astro_app_secret_here

# NASA API Key
NASA_API_KEY=your_nasa_api_key_here

# Mapbox Token（生产环境 - 仅 Vercel 使用）
MAPBOX_ACCESS_TOKEN_PROD=your_mapbox_secret_token_here

# ======== Vercel KV (Upstash Redis) ========
# 创建方式：Vercel 控制台 → Storage → Create Database → Vercel KV
# Vercel 会自动注入这些变量，本地开发需手动填入
KV_URL=your_kv_redis_url
KV_REST_API_URL=your_kv_rest_url
KV_REST_API_TOKEN=your_kv_rest_token
