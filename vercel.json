{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/weather?lat=0&lon=0",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/weather",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/astronomy",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400"
        }
      ]
    }
  ],
  "functions": {
    "api/weather.js": { "maxDuration": 10 },
    "api/astronomy.js": { "maxDuration": 10 },
    "api/phenology.js": { "maxDuration": 10 }
  }
}
