{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/weather?lat=0&lon=0",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/usage-monitor?key=monitor_secret_change_me",
      "schedule": "0 9 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/api/weather",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/astronomy",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=86400"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10
      }
    }
  ]
}
